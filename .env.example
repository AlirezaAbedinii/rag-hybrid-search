# ─────────────────────────────────────────────────────────────────────────────
# RAG hybrid-search — environment configuration
# Copy to `.env` and fill in. Every variable read by src/rag/config.py is listed
# here. Variables are matched case-insensitively to Settings fields.
# Nothing here is required to import the package or run the tests; the API
# key(s) are only required when a code path actually calls a provider.
# ─────────────────────────────────────────────────────────────────────────────

# -- General ------------------------------------------------------------------
APP_ENV=dev
LOG_LEVEL=INFO

# -- Provider selection (pick ONE generation provider — no multi-provider routing) --
# llm_provider:        openai | anthropic
# embedding_provider:  openai | sentence_transformers   (sentence_transformers = offline/free)
LLM_PROVIDER=openai
EMBEDDING_PROVIDER=openai

# -- API keys -----------------------------------------------------------------
# Required for the *active* provider only:
#   - LLM_PROVIDER=openai     -> OPENAI_API_KEY
#   - LLM_PROVIDER=anthropic  -> ANTHROPIC_API_KEY
#   - EMBEDDING_PROVIDER=openai also needs OPENAI_API_KEY
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# -- Model IDs ----------------------------------------------------------------
GENERATION_MODEL=gpt-4o-mini
EMBEDDING_MODEL=text-embedding-3-small
RERANKER_MODEL=cross-encoder/ms-marco-MiniLM-L-6-v2

# -- Token prices (USD per 1,000,000 tokens; cost = tokens * price) -----------
PRICE_GENERATION_INPUT_PER_1M=0.15
PRICE_GENERATION_OUTPUT_PER_1M=0.60
PRICE_EMBEDDING_PER_1M=0.02

# -- Retrieval / fusion / rerank ----------------------------------------------
DEFAULT_MODE=dense
TOP_K=10
RERANK_CANDIDATES=20
RERANK_TOP_K=5
RRF_K=60
RRF_DENSE_WEIGHT=0.7
RRF_SPARSE_WEIGHT=0.3

# -- Chunking -----------------------------------------------------------------
CHUNK_STRATEGY=fixed
CHUNK_SIZE=800
CHUNK_OVERLAP=120

# -- Thresholds ---------------------------------------------------------------
DEDUP_COSINE_THRESHOLD=0.95
RETRIEVAL_CONFIDENCE_THRESHOLD=0.30
CONFIDENCE_THRESHOLD=0.50

# -- Paths (relative paths are resolved against the repo root) ----------------
DATA_RAW_DIR=data/raw
DATA_PROCESSED_DIR=data/processed
CORPUS_DIR=data/raw/ferry_docs
CHROMA_PERSIST_DIR=data/chroma
CHROMA_COLLECTION=ferry_docs
BM25_INDEX_PATH=data/bm25_index.pkl
TRACE_STORE_PATH=data/traces.sqlite
GOLDEN_SET_PATH=eval/golden/golden_set.jsonl
